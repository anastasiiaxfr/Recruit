---
const today = new Date();
import Logo from "../components/Logo.astro";
---

<footer class="footer bg-secondary text-white py-10">
  <div class="container flex flex-wrap gap-3 justify-between items-center">
    <div>
      <Logo />
      <p class="mt-3">
        &copy; {today.getFullYear()} Your Recruit. All rights reserved.
      </p>
    </div>
    <nav class="flex flex-wrap gap-3 items-center">
      <a href="/privacy" class="underline hover:no-underline">Privacy Policy</a>
      <a href="/terms" class="underline hover:no-underline">Terms of Service</a>
    </nav>
  </div>
</footer>
