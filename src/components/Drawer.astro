    ><span class="sr-only">Open menu</span></label
  >
  <nav
    class="menu bg-secondary text-white min-h-full w-80 p-4 flex flex-col gap-3"
  >
    <Logo />
    <hr class="opacity-20 my-4" />
    <HeaderLink href="/">Home</HeaderLink>
    <HeaderLink href="/about">About</HeaderLink>
    <HeaderLink href="/index.html#services">Services</HeaderLink>
    <HeaderLink href="/jobs">Jobs</HeaderLink>
    <HeaderLink href="/blog">Blog & News</HeaderLink>
    <HeaderLink href="/index.html#contacts">Contact</HeaderLink>
  </nav>
</div>
