---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { Menu } from '@lucide/astro';
import Logo from './Logo.astro';

---

<header class="bg-secondary text-white py-4">
<div class="container">
	<nav class="flex items-center justify-between gap-2">
		<Logo />
		
		<label for="my-drawer-2" aria-label="open sidebar" class="btn btn-square btn-ghost hover:bg-primary hover:border-primary text-white rounded-none">
         	<Menu />
        </label>
	</nav>
</div>
</header>
