---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/MainLayout.astro";
import Hero from "../../../components/Hero.astro";
import { ArrowRight } from "@lucide/astro";

const jobs = await getCollection("jobs");
const tags = new Map<string, { name: string; count: number }>();

jobs.forEach((job) => {
  job.data.tags.forEach((tagName) => {
    const slug = tagName
      .trim()
      .toLocaleLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/(^-|-$)/g, "");
    const tag = tags.get(slug);

    tags.set(slug, {
      name: tag?.name ?? tagName,
      count: (tag?.count ?? 0) + 1,
    });
  });
});

const sortedTags = Array.from(tags.entries()).sort(([, a], [, b]) =>
  a.name.localeCompare(b.name),
);
---

<Layout
  title="Job Tags"
  description="Browse job opportunities by technology, skill, or keyword."
>
  <Hero title="Job Tags" />

  <div class="container my-10">
    <nav class="breadcrumbs text-sm" aria-label="Breadcrumb">
      <ul class="flex! flex-wrap">
        <li><a href="/">Home</a></li>
        <li><a href="/jobs/">Jobs</a></li>
        <li>Tags</li>
      </ul>
    </nav>
  </div>

  <section class="section">
    <div class="container">
      <div class="mb-10">
        <p class="text-primary font-semibold uppercase">Browse jobs</p>
        <h2 class="mt-2">All tags</h2>
        <p class="mt-3 text-lg">
          Find vacancies by technology, skill, or area of expertise.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          sortedTags.map(([slug, tag]) => (
            <a
              href={`/jobs/tags/${slug}/`}
              class="group border border-gray-200 p-6 flex items-center justify-between gap-4 hover:border-primary transition-colors"
            >
              <div>
                <h3 class="text-xl font-semibold">#{tag.name}</h3>
                <p class="mt-2 opacity-60">
                  {tag.count} {tag.count === 1 ? "job" : "jobs"}
                </p>
              </div>

              <ArrowRight
                class="shrink-0 group-hover:translate-x-1 transition-transform"
              />
            </a>
          ))
        }
      </div>

      {sortedTags.length === 0 && <p class="text-xl">No job tags found.</p>}
    </div>
  </section>
</Layout>
