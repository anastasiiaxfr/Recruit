---
import { getCollection } from "astro:content";
import Layout from "../../layouts/MainLayout.astro";
import Hero from "../../components/Hero.astro";
import { Search, ArrowRight } from "@lucide/astro";
import Pagination from "../../components/Pagination.astro";

export async function getStaticPaths({ paginate }) {
  const jobs = (await getCollection("jobs")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return paginate(jobs, {
    pageSize: 6,
  });
}

const { page } = Astro.props;
---

<Layout
  title="Jobs"
  description="Lorem ipsum dolor sit amet"
  pubDate={new Date("August 08 2021")}
>
  <Hero title="Jobs" />

  <section class="section bg-light-100 my-0! py-20">
    <div class="container">
      <form action="/" method="GET">
        <div class="join w-full">
          <input
            type="search"
            class="border border-gray-200 w-full bg-white px-3"
            placeholder="Search for job titles..."
          />

          <button
            class="btn btn-lg join-item bg-primary text-secondary hover:bg-secondary hover:text-white shadow-none rounded-none border-primary hover:border-secondary"
          >
            <Search size={20} />
          </button>
        </div>
      </form>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid gap-10">
        {
          page.data.map((post) => (
            <a
              href={`/jobs/${post.id}/`}
              class="border border-gray-200 p-10 relative"
            >
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 pb-10">
                <div class="flex flex-col justify-between">
                  <div>
                    <p class="opacity-50">Job Ref: {post.data.referrer}</p>

                    <h3 class="font-semibold mt-3 mb-2">{post.data.title}</h3>

                    <p class="text-lg mb-6">
                      {post.data.city}, {post.data.country}
                    </p>
                  </div>

                  <p class="text-xl mt-auto">
                    {post.data.currency}
                    {post.data.min_salary.toLocaleString()} -{" "}
                    {post.data.currency}
                    {post.data.max_salary.toLocaleString()}{" "}
                    {post.data.salary_period}
                  </p>
                </div>

                <div class="grid gap-3">
                  <p class="whitespace-pre-line">{post.data.description}</p>
                </div>
              </div>

              <button
                class="btn btn-square bg-primary text-secondary hover:bg-secondary hover:text-white shadow-none rounded-none border-none btn-lg absolute right-0 bottom-0"
                title="Next"
              >
                <ArrowRight />
              </button>
            </a>
          ))
        }
      </div>

      {page.lastPage > 1 && <Pagination page={page} />}
    </div>
  </section>
</Layout>
